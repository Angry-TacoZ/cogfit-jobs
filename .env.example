# Firebase web app config. These values are public Firebase client config, not model secrets.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=cogfit-jobs.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=cogfit-jobs
VITE_FIREBASE_APP_ID=

# Required for protected live evaluation. Create this in Firebase App Check.
VITE_FIREBASE_APPCHECK_SITE_KEY=
