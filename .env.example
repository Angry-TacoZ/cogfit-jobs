# Local dev only. Production loads Firebase config from Firebase Hosting /__/firebase/init.json.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=cogfit-jobs.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=cogfit-jobs
VITE_FIREBASE_APP_ID=

# Required for protected live evaluation. Create this in Firebase App Check.
VITE_FIREBASE_APPCHECK_SITE_KEY=

# Server-only secret. Set with Firebase Functions Secret Manager, never in Vite env.
# firebase functions:secrets:set GEMINI_API_KEY --project cogfit-jobs
